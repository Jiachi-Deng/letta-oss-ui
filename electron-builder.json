{
    "appId": "com.jachi.letta",
    "productName": "Letta",
    "files": [
        "dist-electron",
        "dist-react"
    ],
    "extraResources": [
        {
            "from": "dist-electron/preload.cjs",
            "to": "dist-electron/preload.cjs"
        },
        {
            "from": "templateIcon.png",
            "to": "templateIcon.png"
        },
        {
            "from": "build-resources/CodeIsland.app",
            "to": "CodeIsland.app"
        },
        {
            "from": "build-resources/LettaServer",
            "to": "LettaServer"
        }
    ],
    "asarUnpack": [
        "node_modules/@letta-ai/letta-code-sdk/**/*",
        "node_modules/@letta-ai/letta-code/**/*",
        "node_modules/@letta-ai/letta-client/**/*",
        "node_modules/glob/**/*",
        "node_modules/highlight.js/**/*",
        "node_modules/ink-link/**/*",
        "node_modules/lowlight/**/*",
        "node_modules/open/**/*",
        "node_modules/sharp/**/*",
        "node_modules/ws/**/*"
    ],
    "mac": {
        "icon": "templateIcon.png",
        "timestamp": "none",
        "target": [
            "dmg",
            "zip"
        ]
    },
    "linux": {
        "target": "AppImage",
        "category": "Utility"
    },
    "win": {
        "target": [
            "portable"
        ]
    }
}
